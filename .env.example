# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 16
RELAY_SECRET=change-me-32-char-random-string

RELAY_ADMIN_USER=admin
RELAY_ADMIN_PASS=changeme

# ── Public status page ────────────────────────────────────────────────────────
RELAY_SITE_NAME=Acme Status
RELAY_SITE_URL=https://status.example.com
RELAY_LOGO_URL=   # optional: URL to your logo image

# ── Email notifications & subscriber confirmations ────────────────────────────
RELAY_SMTP_HOST=smtp.example.com
RELAY_SMTP_PORT=587
RELAY_SMTP_USER=alerts@example.com
RELAY_SMTP_PASS=
RELAY_SMTP_FROM=Relay Alerts <alerts@example.com>

# ── Optional tuning ───────────────────────────────────────────────────────────
RELAY_DATA=/data              # Where SQLite stores relay.db
RELAY_PORT=8080
RELAY_LOG_LEVEL=info          # debug | info | warn | error
RELAY_CHECK_CONCURRENCY=20    # Max concurrent checks
RELAY_RETENTION_DAYS=90       # Days of check history to keep
RELAY_TZ=UTC
